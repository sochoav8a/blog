---
import Base from '../../layouts/Base.astro';
import AsciiRail from '../../components/AsciiRail.astro';
import { railLeft, railRight } from '../../ascii/rails';
import { getPublishedPosts, formatDate, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Set(posts.flatMap((post) => post.data.tags));
  return [...tags].map((tag) => ({
    params: { tag },
    props: { posts: posts.filter((post) => post.data.tags.includes(tag)) },
  }));
}

interface Props {
  posts: Post[];
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Base title={`#${tag}`} description={`Posts etiquetados con #${tag}`}>
  <AsciiRail slot="rail-left" art={railLeft} align="left" />
  <AsciiRail slot="rail-right" art={railRight} align="right" />

  <h1 class="text-lg font-bold text-accent">#{tag}</h1>
  <ul class="mt-10 flex flex-col gap-5">
    {
      posts.map((post) => (
        <li class="flex flex-col gap-x-5 gap-y-0 sm:flex-row sm:items-baseline">
          <time
            datetime={post.data.date.toISOString()}
            class="shrink-0 font-mono text-xs text-muted"
          >
            {formatDate(post.data.date)}
          </time>
          <a href={`/posts/${post.id}/`} class="no-underline hover:text-accent">
            {post.data.title}
          </a>
        </li>
      ))
    }
  </ul>
</Base>
