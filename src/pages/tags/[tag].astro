---
import Base from '../../layouts/Base.astro';
import { getPublishedPosts, formatDate, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Set(posts.flatMap((post) => post.data.tags));
  return [...tags].map((tag) => ({
    params: { tag },
    props: { posts: posts.filter((post) => post.data.tags.includes(tag)) },
  }));
}

interface Props {
  posts: Post[];
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Base title={`#${tag}`} description={`Posts etiquetados con #${tag}`}>
  <h1 class="text-2xl">#{tag}</h1>
  <ul class="mt-8 flex flex-col gap-4">
    {
      posts.map((post) => (
        <li class="flex items-baseline gap-4">
          <time
            datetime={post.data.date.toISOString()}
            class="shrink-0 font-sans text-sm text-muted"
          >
            {formatDate(post.data.date)}
          </time>
          <a href={`/posts/${post.id}/`} class="no-underline hover:text-accent">
            {post.data.title}
          </a>
        </li>
      ))
    }
  </ul>
</Base>
