---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getPublishedPosts, formatDate, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={`/og/${post.id}.png`}
  ogType="article"
>
  <article>
    <header class="mb-10">
      <h1 class="text-3xl">{post.data.title}</h1>
      <p class="mt-3 font-sans text-sm text-muted">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {
          post.data.updated && (
            <>
              {' · actualizado el '}
              <time datetime={post.data.updated.toISOString()}>
                {formatDate(post.data.updated)}
              </time>
            </>
          )
        }
      </p>
      {
        post.data.tags.length > 0 && (
          <ul class="mt-2 flex gap-3 font-sans text-sm">
            {post.data.tags.map((tag) => (
              <li>
                <a href={`/tags/${tag}/`} class="text-muted no-underline hover:text-accent">
                  #{tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
