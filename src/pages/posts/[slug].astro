---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getPublishedPosts, formatDate, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={`/og/${post.id}.png`}
  ogType="article"
>
  <article>
    <header class="mb-12">
      <p class="font-mono text-xs text-muted">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {
          post.data.updated && (
            <>
              {' · act. '}
              <time datetime={post.data.updated.toISOString()}>
                {formatDate(post.data.updated)}
              </time>
            </>
          )
        }
        {
          post.data.tags.length > 0 && (
            <>
              {' · '}
              {post.data.tags.map((tag, i) => (
                <>
                  {i > 0 && ' '}
                  <a href={`/tags/${tag}/`} class="no-underline hover:text-accent">
                    #{tag}
                  </a>
                </>
              ))}
            </>
          )
        }
      </p>
      <h1 class="mt-4 text-2xl font-semibold">{post.data.title}</h1>
      <p class="mt-4 text-lg italic text-muted">{post.data.description}</p>
    </header>
    <div class="prose">
      <Content />
    </div>
    <p class="mt-16 font-mono text-xs text-muted" aria-hidden="true">EOF</p>
  </article>
</Base>
